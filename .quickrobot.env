# .quickrobot.env — System engine configuration
# Format: KEY=value (plain text, no quotes needed for simple values)
# IPv6-compatible: use [addr] bracket notation where applicable
# Example: QUICKROBOT_API_HOST=[::1] for IPv6 loopback
#          QUICKROBOT_MCP_HOST=[fe80::1%eth0] for link-local IPv6
#
# Ownership: Human-edited only. No server process writes to this file.
# Single source of truth for system engine network config.
# Missing file = all system engines error out at startup with help text.


# =========================================================================
# WebUI - Ape control interface
# =========================================================================

QUICKROBOT_WEBUI_HOST=127.0.0.1
QUICKROBOT_WEBUI_PORT=8040
QUICKROBOT_WEBUI_AUTOSTART=true

# =========================================================================
# API Server - Agent Control interface
# =========================================================================

QUICKROBOT_API_HOST=127.0.0.1
QUICKROBOT_API_PORT=8041

# ansible_user (empty = dynamic getpass)
# QUICKROBOT_API_ANSIBLE_SSHUSER=mepaw
# ansible_key_path → QUICKROBOT_API_ANSIBLE_SSHKEY (empty = ssh-agent)
# QUICKROBOT_API_ANSIBLE_SSHKEY=/home/user/.ssh/id_ed25519

# ping_command (only for display)
QUICKROBOT_API_PING_COMMAND=ping -c1 -W2 {host}

# ping_interval 
QUICKROBOT_API_PING_INTERVAL=120

# Model base "scan" path — default model root for nodes/hosts on creation.
# Can be overridden per-node via PUT /api/v1/nodes/<id>.
QUICKROBOT_API_MODEL_BASE_PATH=/mnt/llama/gguf/models

# =========================================================================
# MCP Server - Chat Control Interface
# =========================================================================

QUICKROBOT_MCP_HOST=127.0.0.1
QUICKROBOT_MCP_PORT=8042
QUICKROBOT_MCP_AUTOSTART=true

#Can be set synamic in webui:
QUICKROBOT_MCP_READ=true
QUICKROBOT_MCP_WRITE=false
QUICKROBOT_MCP_FULLPROXY=false

# Disable DNS rebinding protection (recommended for LAN deployments where
# multiple hosts on the same subnet connect to the MCP server).
# When disabled, any host header is accepted.
# Set to "false" to re-enable host validation with QUICKROBOT_MCP_ALLOWED_HOSTS.

QUICKROBOT_MCP_DISABLE_DNS_REBINDING=true
# Comma-separated allowed host patterns (only used when DNS rebinding is enabled).
# Pattern format: "host:*" where * matches any port. Example: "192.168.31.*:*"

QUICKROBOT_MCP_ALLOWED_HOSTS=192.168.31.*:*,127.0.0.1:*,localhost:*,[::1]:*,192.168.18.*:*

# =========================================================================
# Spawn timeout (seconds)
# Time to wait for old process to exit before killing it during restart.
# Must be an integer >= 1.
# =========================================================================

QUICKROBOT_SERVER_SPAWN_TIMEOUT=5

# =========================================================================
# Logging configuration
# =========================================================================
# Console debug level — numeric, 0 = quiet, >= 10 = verbose debug output
# QUICKROBOT_CONSOLE_DEBUG_LEVEL=10
# Ansible action DB log level — "errors" (default), "warnings", "all"
# "errors" only logs failures/timeouts to ansible_actions table.
# "warnings" also logs non-failed changes (apt updates, config-only deploys).
# "all" logs every playbook execution.

QUICKROBOT_ANSIBLE_LOG_LEVEL=all

# =========================================================================
# Seed file verification
# =========================================================================

QUICKROBOT_SEED_CHECKSUM=53e86a9ac8dcdbf73dae2425e40f3e017dfb1e60664678556dd44d1a2e2d1ae9
QUICKROBOT_SEED_FILESIZE=80829
QUICKROBOT_SEED_MAX_ID=1000

# =========================================================================
# Create-fail cleanup — when true, orphaned nodes/instances are removed
# from DB on creation failure (default: true). When false, legacy behavior:
# partially-created records are kept for debugging.
# =========================================================================

QUICKROBOT_CLEANUP_ON_CREATE_FAIL=true

# =========================================================================
# Database backup retention
# Number of database backup files to keep in data/_backups/ (default: 5)
# Set to 0 to keep all backups.
# =========================================================================
# BROKEN? TODO 

QUICKROBOT_MAX_BACKUPS=5

# =========================================================================
# SSH connection settings — override defaults from qr_engine_ids.py
# =========================================================================

# Strict host key checking: "yes" (prompt) | "accept-new" (headless safe) | "no" (insecure)
QUICKROBOT_SSH_STRICT_HOST_KEY_CHECKING=accept-new

# SSH connection timeout in seconds
QUICKROBOT_SSH_CONNECT_TIMEOUT=5

# playbook_root_dir → QUICKROBOT_API_PLAYBOOKDIR
QUICKROBOT_API_PLAYBOOKDIR=playbooks/

# =========================================================================
# SSL/TLS (future — uncomment when enabling HTTPS)
# Paths must be absolute. Cert and key must be readable by the process user.
# =========================================================================
# NOT INGAME!
QUICKROBOT_WEBUI_BEARER_TOKEN=<random-token>
QUICKROBOT_MCP_BEARER_TOKEN=<random-token>
QUICKROBOT_API_BEARER_TOKEN=<random-token> 
# QUICKROBOT_API_SSL_CERT=/opt/quickrobot/certs/api.crt
# QUICKROBOT_API_SSL_KEY=/opt/quickrobot/certs/api.key
# QUICKROBOT_WEBUI_SSL_CERT=/opt/quickrobot/certs/webui.crt
# QUICKROBOT_WEBUI_SSL_KEY=/opt/quickrobot/certs/webui.key
# QUICKROBOT_MCP_SSL_CERT=/opt/quickrobot/certs/mcp.crt
# QUICKROBOT_MCP_SSL_KEY=/opt/quickrobot/certs/mcp.key
# NOT INGAME!
